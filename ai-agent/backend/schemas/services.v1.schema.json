{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "services.v1",
  "title": "ServicesV1",
  "description": "DBAAS 服务列表快照。结构必须与 dbaas-server GET /services 响应一致，顶层为服务组数组。",
  "type": "array",
  "items": {
    "$ref": "#/$defs/ServiceDetailResponse"
  },
  "$defs": {
    "BackupStrategySummary": {
      "type": "object",
      "additionalProperties": false,
      "description": "服务组对应的备份策略摘要。",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "是否启用备份"
        },
        "type": {
          "type": ["string", "null"],
          "default": null,
          "description": "备份类型"
        },
        "cronExpression": {
          "type": ["string", "null"],
          "default": null,
          "description": "备份 cron 表达式"
        },
        "retention": {
          "type": ["integer", "null"],
          "default": null,
          "description": "备份保留天数"
        },
        "compressMode": {
          "type": ["string", "null"],
          "default": null,
          "description": "压缩模式"
        },
        "sendAlarm": {
          "type": ["boolean", "null"],
          "default": null,
          "description": "是否发送告警"
        }
      }
    },
    "ChildService": {
      "type": "object",
      "additionalProperties": false,
      "description": "服务组中的子服务信息。",
      "required": ["name", "type", "healthStatus"],
      "properties": {
        "name": {
          "type": "string",
          "description": "子服务名称"
        },
        "type": {
          "type": "string",
          "description": "子服务类型"
        },
        "version": {
          "type": ["string", "null"],
          "default": null,
          "description": "子服务版本"
        },
        "port": {
          "type": ["integer", "null"],
          "default": null,
          "description": "服务端口"
        },
        "healthStatus": {
          "type": "string",
          "description": "子服务健康状态，例如 HEALTHY、DEGRADED、UNHEALTHY"
        },
        "clusterHA": {
          "type": ["boolean", "null"],
          "default": null,
          "description": "是否开启集群高可用"
        },
        "nodeHA": {
          "type": ["boolean", "null"],
          "default": null,
          "description": "是否开启节点高可用"
        },
        "platformAuto": {
          "type": ["boolean", "null"],
          "default": null,
          "description": "是否由平台自动分配规格"
        },
        "units": {
          "type": "array",
          "default": [],
          "description": "子服务下的单元列表",
          "items": {
            "$ref": "#/$defs/ServiceUnit"
          }
        }
      }
    },
    "ServiceDetailResponse": {
      "type": "object",
      "additionalProperties": false,
      "description": "GET /services/{name} 的响应模型；GET /services 返回该对象数组。",
      "required": [
        "name",
        "type",
        "subsystem",
        "environment",
        "siteId",
        "siteName",
        "region",
        "zone",
        "healthStatus",
        "network"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "服务组名称"
        },
        "type": {
          "type": "string",
          "description": "服务组类型"
        },
        "user": {
          "type": ["string", "null"],
          "default": null,
          "description": "服务组所属用户，也是普通用户可见性过滤字段"
        },
        "subsystem": {
          "type": "string",
          "description": "服务组所属子系统"
        },
        "environment": {
          "type": "string",
          "description": "服务组所在环境，例如 prod、staging、dev、perf"
        },
        "siteId": {
          "type": "string",
          "description": "服务组所属站点 ID"
        },
        "siteName": {
          "type": "string",
          "description": "服务组所属站点名称"
        },
        "region": {
          "type": "string",
          "description": "服务组所在区域"
        },
        "zone": {
          "type": "string",
          "description": "服务组所在可用区"
        },
        "architecture": {
          "type": ["string", "null"],
          "default": null,
          "description": "服务组架构描述"
        },
        "sharding": {
          "type": ["boolean", "null"],
          "default": null,
          "description": "是否为分片结构"
        },
        "healthStatus": {
          "type": "string",
          "description": "服务组健康状态，例如 HEALTHY、DEGRADED、UNHEALTHY"
        },
        "network": {
          "$ref": "#/$defs/ServiceNetworkSpec",
          "description": "服务组网络信息"
        },
        "services": {
          "type": "array",
          "default": [],
          "description": "服务组下的子服务列表",
          "items": {
            "$ref": "#/$defs/ChildService"
          }
        },
        "backupStrategy": {
          "anyOf": [
            {
              "$ref": "#/$defs/BackupStrategySummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "服务组备份策略摘要，运行时可由备份策略数据合并得到"
        }
      }
    },
    "ServiceNetworkSpec": {
      "type": "object",
      "additionalProperties": false,
      "description": "服务组网络信息。",
      "required": ["vpcId", "subnetId", "cidr", "gateway"],
      "properties": {
        "vpcId": {
          "type": "string",
          "description": "服务组所在 VPC ID"
        },
        "subnetId": {
          "type": "string",
          "description": "服务组所在子网 ID"
        },
        "cidr": {
          "type": "string",
          "description": "服务组所在子网网段"
        },
        "gateway": {
          "type": "string",
          "description": "服务组所在子网网关"
        }
      }
    },
    "ServiceStorageSpec": {
      "type": "object",
      "additionalProperties": false,
      "description": "单元存储规格。",
      "required": ["data", "log"],
      "properties": {
        "data": {
          "$ref": "#/$defs/ServiceVolumeSpec",
          "description": "data 卷规格"
        },
        "log": {
          "$ref": "#/$defs/ServiceVolumeSpec",
          "description": "log 卷规格"
        }
      }
    },
    "ServiceUnit": {
      "type": "object",
      "additionalProperties": false,
      "description": "子服务下的单元信息。",
      "required": [
        "id",
        "name",
        "type",
        "role",
        "healthStatus",
        "containerStatus",
        "hostId",
        "hostName",
        "hostIp",
        "containerIp",
        "storage"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "单元唯一标识"
        },
        "name": {
          "type": "string",
          "description": "单元名称"
        },
        "type": {
          "type": "string",
          "description": "单元类型，例如 docker"
        },
        "role": {
          "type": "string",
          "description": "单元角色，例如 primary、replica、proxy、manager"
        },
        "image": {
          "type": ["string", "null"],
          "default": null,
          "description": "单元容器镜像名称"
        },
        "version": {
          "type": ["string", "null"],
          "default": null,
          "description": "单元真实版本，例如 8.0.36"
        },
        "healthStatus": {
          "type": "string",
          "description": "单元健康状态，例如 HEALTHY、DEGRADED、UNHEALTHY"
        },
        "containerStatus": {
          "type": "string",
          "description": "单元容器状态，例如 RUNNING、STOPPED、RESTARTING"
        },
        "hostId": {
          "type": "string",
          "description": "单元所在主机 ID"
        },
        "hostName": {
          "type": "string",
          "description": "单元所在主机名称"
        },
        "hostIp": {
          "type": "string",
          "description": "单元所在主机 IP"
        },
        "containerIp": {
          "type": "string",
          "description": "单元容器 IP"
        },
        "cpu": {
          "type": ["number", "null"],
          "default": null,
          "description": "CPU 核数"
        },
        "memory": {
          "type": ["number", "null"],
          "default": null,
          "description": "内存大小"
        },
        "storage": {
          "$ref": "#/$defs/ServiceStorageSpec",
          "description": "单元存储规格"
        }
      }
    },
    "ServiceVolumeSpec": {
      "type": "object",
      "additionalProperties": false,
      "description": "单元 volume 规格。",
      "required": ["diskId", "diskName", "diskType", "mediaType", "mountPoint", "size"],
      "properties": {
        "diskId": {
          "type": "string",
          "description": "挂载目标主机磁盘 ID"
        },
        "diskName": {
          "type": "string",
          "description": "挂载目标主机磁盘名称"
        },
        "diskType": {
          "type": "string",
          "description": "挂载目标主机磁盘用途，例如 data、log"
        },
        "mediaType": {
          "type": "string",
          "description": "挂载目标主机磁盘介质类型，例如 SSD、HDD"
        },
        "mountPoint": {
          "type": "string",
          "description": "容器内挂载路径"
        },
        "size": {
          "type": "number",
          "description": "卷容量大小"
        }
      }
    }
  }
}
